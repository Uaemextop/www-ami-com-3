   <div class="iw_component" id="iw_comp1639070922589">
     <!--ls:begin[component-1639070922589]--><style>#iw_comp1639070922589{}</style><div class="collapse-mobile sp-supported-ste additional dtmCommonSection" id="features">
    <h3>Features</h3>
    <div class="features-list" id="featuresXsp">
        <div class="features-xsp">
            <div class="collapse-mobile ste-list">
                <h3>Multicore Processing</h3>

                <ul class="boxes">
                    <li>1-2x Arm® Cortex®-A55 @ 1.7 GHz</li>
                    <li>Arm Cortex-M33 @ 250Mhz</li>
                    <li>Arm® Ethos™ U-65 microNPU</li>
                    <li>EdgeLock® secure enclave</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Connectivity</h3>

                <ul class="boxes">
                    <li>2x USB 2.0 Type C with PHY</li>
                    <li>2x Gb Ethernet: AVB and IEEE 1588 for sync, and EEE for low power. 1 with TSN</li>
                    <li>2x CAN FD</li>
                    <li>8x UART, 8x I²C, 8x SPI, 2x I3C</li>
                    <li>1x 4-ch, 12-bit ADC</li>
                    <li>2x 32-pin FlexIO interfaces (camera, bus or serial I/O)</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>External Memory</h3>

                <ul class="boxes">
                    <li>Up to 3.7GT/s x16 LPDDR4/LPDDR4X (with Inline ECC)</li>
                    <li>3x SD 3.0/ SDIO3.0/ eMMC5.1</li>
                    <li>1x Octal SPI, including support for SPI NOR and SPI NAND memories</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Graphics</h3>

                <ul class="boxes">
                    <li>Hardware Compositor for Blending/Composition, Resize, Color Space Conversion</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Display Interfaces</h3>

                <ul class="boxes">
                    <li>1x 1080p60 MIPI-DSI (4-lane, 1.5Gbps/lane) with PHY</li>
                    <li>1x 720p60 LVDS (4-lane)</li>
                    <li>24-bit parallel RGB</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Camera Interfaces</h3>

                <ul class="boxes">
                    <li>1x 1080p60 MIPI-CSI (2-lane, 1.5Gbps/lane) with PHY</li>
                    <li>8-bit parallel YUV/RGB</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Audio</h3>

                <ul class="boxes">
                    <li>7x I2S TDM (32-bit @ 768KHz), SPDIF Tx/Rx</li>
                    <li>8 channel PDM microphone input</li>
                    <li>MQS: Medium Quality Sound output (sigma-delta modulator)</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Operating Systems</h3>

                <ul class="boxes">
                    <li>
                        Linux® OS
                    </li>
                    <li>FreeRTOS</li>
                    <li>Greenhills</li>
                    <li>QNX</li>
                    <li>VxWorks</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Packaging</h3>

                <ul class="boxes">
                    <li>11 mm x 11 mm, 0.5 mm pitch FCBGA</li>
                    <li>9 mm x 9 mm, 0.5 mm pitch FCBGA</li>
                    <li>14 mm x 14 mm, 0.65 mm pitch FCBGA</li>
                </ul>
            </div>
            <div class="collapse-mobile ste-list">
                <h3>Temp Range</h3>

                <ul class="boxes">
                    <li>-40 C° to 125 C°</li>
                </ul>
            </div>
        </div>
    </div>
</div><!--ls:end[component-1639070922589]--> 
   </div> 
